{
  "name": "imessage-mcp-server",
  "version": "1.5.0",
  "description": "Enhanced iMessage MCP Server for Claude Desktop with multi-handle support and sentiment analysis",
  "repository": {
    "type": "git",
    "url": "https://github.com/johnroelant/Claude-Enhanced-Desktop-iMessage-Connector.git"
  },
  "homepage": "https://github.com/johnroelant/Claude-Enhanced-Desktop-iMessage-Connector",
  "bugs": {
    "url": "https://github.com/johnroelant/Claude-Enhanced-Desktop-iMessage-Connector/issues"
  },
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "debug": "node --inspect --watch index.js",
    "inspect": "npx -y @modelcontextprotocol/inspector node index.js",
    "inspect:debug": "npx -y @modelcontextprotocol/inspector node --inspect index.js",
    "test": "bash ../scripts/test-tools.sh all",
    "test:list": "bash ../scripts/test-tools.sh list",
    "test:integration": "node --test test/smoke.test.js test/tools/search_contacts.test.js test/tools/search_and_read.test.js test/tools/read_conversation.test.js test/tools/get_conversation_stats.test.js test/tools/analyze_message_sentiment.test.js",
    "test:applescript": "node --test test/applescript-parsing.test.js",
    "test:all": "npm run test:integration && npm run test",
    "build": "npx @anthropic-ai/mcpb pack"
  },
  "keywords": [
    "mcp",
    "imessage",
    "claude",
    "sqlite",
    "messages",
    "claude-desktop",
    "connector",
    "enhanced",
    "multi-handle",
    "sentiment-analysis"
  ],
  "author": "jjroelant@gmail.com",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.26.0",
    "sqlite3": "^5.1.7",
    "sqlite": "^5.1.1"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
